# PARASITE Benchmark — Environment Variables
# Copy to .env and fill in your keys.

# ── Required (for respective providers) ──────────────────────────────
OPENAI_API_KEY=sk-...          # OpenAI GPT / o-series models
ANTHROPIC_API_KEY=sk-ant-...   # Anthropic Claude models

# ── Optional ─────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...   # OpenRouter: routes all models through openrouter.ai
ZAI_API_KEY=...                # Z.AI GLM models (Zhipu)
VERCEL_AI_GATEWAY_KEY=...      # Vercel AI Gateway (provider/model format)
